<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProjetoLAWBD</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjetoLAWBD.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@fancyapps/ui@5.0/dist/fancybox/fancybox.css" />

    

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/icons/website-icon.svg" alt="Icon" width="26" height="26" class="ms-4 me-3" />
                </a>
                
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">AutoMarket</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted" style="line-height: normal; padding-top: 10px; padding-bottom: 10px; background-color: #ffffff">

        <div class="container text-center">
            <div class="mb-1 d-flex flex-wrap justify-content-center gap-3" style="font-size: 0.85rem;">
                <a asp-controller="Home" asp-action="Sobre" class="text-muted text-decoration-none mx-2">Sobre</a>
                <a asp-controller="Home" asp-action="Ajuda" class="text-muted text-decoration-none mx-2">Ajuda</a>
                <a asp-controller="Home" asp-action="Privacidade" class="text-muted text-decoration-none mx-2">Privacidade</a>
                <a asp-controller="Home" asp-action="Termos" class="text-muted text-decoration-none mx-2">Termos</a>
                <a asp-controller="Home" asp-action="Contactos" class="text-muted text-decoration-none mx-2">Contactos</a>
            </div>

            <div style="font-size: 0.85rem;">
                &copy; @DateTime.Now.Year AutoMarket. Todos os direitos reservados.
            </div>

        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/Ajax/jquery.unobtrusive-ajax.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@fancyapps/ui@5.0/dist/fancybox/fancybox.umd.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

    

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
