@using Microsoft.AspNetCore.Identity
@{
    Layout = "~/Views/Shared/_DashboardLayoutBase.cshtml";

    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString();
    bool isManagePage = currentPage?.StartsWith("/Account/Manage") ?? false;
}

@section Sidebar {
    <div class="col-md-3 sidebar-vendedor">
        <div class="sidebar-card">
            <div class="text-center mb-4">
                <div class="user-avatar mb-2">
                    <span class="avatar-placeholder">@(User.Identity?.Name?.Substring(0, 1) ?? "U")</span>
                </div>
                <h5 class="mb-0">@User.Identity?.Name</h5>
            </div>

            <ul class="nav flex-column nav-vendedor">
                <li class="nav-item">
                    <a class="nav-link text-dark @(ViewData["ActivePage"] as string == "Compras" ? "active" : "")"
                       asp-controller="Comprador" asp-action="MinhasCompras">
                        As Minhas Compras
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark @(ViewData["ActivePage"] as string == "Reservas" ? "active" : "")"
                       asp-controller="Comprador" asp-action="ReservasVisitas">
                       Reservas e Visitas
                   </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark @(ViewData["ActivePage"] as string == "Marcas" ? "active" : "")"
                       asp-controller="Comprador" asp-action="MarcasFavoritas">
                       Marcas Favoritas
                   </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark @(ViewData["ActivePage"] as string == "Filtros" ? "active" : "")"
                       asp-controller="Comprador" asp-action="PesquisasGuardadas">
                        Filtros de Pesquisa
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark @(ViewData["ActivePage"] as string == "Notificacoes" ? "active" : "")"
                       asp-controller="Comprador" asp-action="Notificacoes">
                       Notificacoes
                   </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(isManagePage ? "active" : "")"
                       asp-area="Identity" asp-page="/Account/Manage/Index">
                        O Meu Perfil
                    </a>
                </li>

                @if (isManagePage)
                {
                    <ul class="nav flex-column nav-sub-menu">
                        <!-- (Links do sub-menu "O Meu Perfil") -->
                        <li class="nav-item">
                            <a class="nav-link @(currentPage == "/Account/Manage/Index" ? "active-sub" : "")"
                               asp-area="Identity" asp-page="/Account/Manage/Index">
                                Perfil
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentPage == "/Account/Manage/Email" ? "active-sub" : "")"
                               asp-area="Identity" asp-page="/Account/Manage/Email">
                                Email
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentPage == "/Account/Manage/ChangePassword" ? "active-sub" : "")"
                               asp-area="Identity" asp-page="/Account/Manage/ChangePassword">
                                Palavra-passe
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentPage == "/Account/Manage/TwoFactorAuthentication" ? "active-sub" : "")"
                               asp-area="Identity" asp-page="/Account/Manage/TwoFactorAuthentication">
                                Autenticação 2 Fatores
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentPage == "/Account/Manage/ExternalLogins" ? "active-sub" : "")"
                               asp-area="Identity" asp-page="/Account/Manage/ExternalLogins">
                                Logins Externos
                            </a>
                        </li>
                    </ul>
                }
            </ul>
        </div>
    </div>
}

@section Styles {
    @await RenderSectionAsync("Styles", required: false)
}

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
}

@RenderBody()