@model ProjetoLAWBD.Models.ConfNotificacoes
@{
    ViewData["Title"] = "Definições de Notificação";
    ViewData["ActivePage"] = "Notificacoes";
    Layout = "~/Views/Shared/_CompradorLayout.cshtml";
}

<h3 class="fw-bold mb-2">Definições de Notificação</h3>
<p class="text-muted mb-4">Escolha como e quando quer ser notificado.</p>

<div class="d-flex flex-column gap-3">

    <div class="card shadow-sm border-0 py-2" style="border-radius: 12px;">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h6 class="fw-bold mb-1">Novos anúncios de marcas favoritas</h6>
                <p class="text-muted small mb-0">Receber um email quando um carro de uma das suas marcas favoritas for publicado.</p>
            </div>
            <div class="form-check form-switch fs-4">
                <input class="form-check-input" type="checkbox" role="switch"
                       @(Model.AnunciosMarcasFavoritas ? "checked" : "")
                       onchange="gravarDefinicao('marcas', this.checked)">
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 py-2" style="border-radius: 12px;">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h6 class="fw-bold mb-1">Alterações nas minhas reservas/visitas</h6>
                <p class="text-muted small mb-0">Receber um email quando um vendedor aprovar ou rejeitar um dos seus pedidos.</p>
            </div>
            <div class="form-check form-switch fs-4">
                <input class="form-check-input" type="checkbox" role="switch"
                       @(Model.AlteracoesReservasVisitas ? "checked" : "")
                       onchange="gravarDefinicao('reservas', this.checked)">
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        // Função AJAX para gravar sem refresh à página
        function gravarDefinicao(campo, valor) {
            $.ajax({
                url: '@Url.Action("AtualizarDefinicao", "Comprador")',
                type: 'POST',
                data: {
                    campo: campo,
                    valor: valor,
                    // Token de segurança obrigatório no ASP.NET
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function() {
                    console.log("Preferência guardada com sucesso.");
                },
                error: function() {
                    alert("Erro ao ligar ao servidor. Tente novamente.");
                }
            });
        }
    </script>
}