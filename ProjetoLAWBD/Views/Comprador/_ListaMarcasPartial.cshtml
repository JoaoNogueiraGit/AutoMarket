@model List<ProjetoLAWBD.Models.MarcaFavoritaComprador>

@foreach (var item in Model)
{
    <div class="card mb-3 border-0 bg-light">
        <div class="card-body d-flex justify-content-between align-items-center py-3">

            <h6 class="mb-0 fw-bold text-dark">@item.Marca.Nome</h6>

            <form asp-action="RemoverMarcaFavorita" asp-controller="Comprador" method="post"
                  data-ajax="true"
                  data-ajax-method="post"
                  data-ajax-mode="replace"
                  data-ajax-update="#lista-marcas">

                <input type="hidden" name="idMarca" value="@item.IdMarca" />
                <button type="submit" class="btn btn-link text-danger text-decoration-none small fw-bold">
                    Remover
                </button>
            </form>

        </div>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center text-muted p-4 border rounded bg-white">
        Ainda não adicionaste nenhuma marca favorita.
    </div>
}