@model ProjetoLAWBD.ViewModels.GerirUtilizadoresViewModel
@{
    ViewData["Title"] = "Gerir Utilizadores";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mt-3">@ViewData["Title"]</h1>
    <a asp-action="CriarAdministrador" class="btn btn-primary">+ Novo Administrador</a>
</div>

<form asp-action="GerirUtilizadores" method="get"
         data-ajax="true" data-ajax-method="GET" data-ajax-update="#tabelaUtilizadoresContainer"
      style="position: relative; z-index: 1050;">

    <div class="d-flex mb-3 align-items-center">
        <span class="me-2">Filtrar por:</span>

        <select name="filtroTipo" asp-for="FiltroTipo" asp-items="Model.Tipos" class="form-select me-2" style="max-width: 200px;">
            <option value="">Todos os Tipos</option>
        </select>

        <select name="filtroEstado" asp-for="FiltroEstado" asp-items="Model.Estados" class="form-select" style="max-width: 200px;">
            <option value="">Todos os Estados</option>
        </select>

        <button type="submit" class="btn btn-primary ms-2">Filtrar</button>
        <a asp-action="GerirUtilizadores" class="btn btn-link text-muted">Limpar</a>
    </div>
</form>

<div class="card shadow-sm anuncio-card" style="overflow: visible !important;">
    <div class="card-body" id="tabelaUtilizadoresContainer">
        @await Html.PartialAsync("_UtilizadoresTable", Model)
    </div>
</div>

<div class="modal fade" id="bloquearModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Bloquear" method="post"
                  data-ajax="true" data-ajax-method="POST"
                  data-ajax-update="#tabelaUtilizadoresContainer"
                  data-ajax-success="fecharModalBloqueio">

                <input type="hidden" name="filtroTipo" value="@Model.FiltroTipo" />
                <input type="hidden" name="filtroEstado" value="@Model.FiltroEstado" />
                <input type="hidden" name="pagina" value="@Model.PaginaAtual" />

                <div class="modal-body">
                    <p>Bloquear acesso de <b id="bloquearUserName"></b>?</p>
                    <input type="hidden" name="id" id="bloquearUserId" />
                    <div class="mb-3">
                        <label class="form-label">Motivo do Bloqueio *</label>
                        <textarea name="motivo" id="motivoBloqueio" class="form-control" rows="3" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Confirmar Bloqueio</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-ajax-unobtrusive/3.2.6/jquery.unobtrusive-ajax.min.js"></script>
    <script>
        // Fechar modal após sucesso do Ajax
        function fecharModalBloqueio() {
            var modalEl = document.getElementById('bloquearModal');
            var modal = bootstrap.Modal.getInstance(modalEl);
            modal.hide();
            document.getElementById('motivoBloqueio').value = ''; // Limpa o texto
        }

        // Script de transferência de dados para o modal (o que já tinhas)
        var bloquearModal = document.getElementById('bloquearModal');
        bloquearModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            document.getElementById('bloquearUserName').textContent = button.getAttribute('data-username');
            document.getElementById('bloquearUserId').value = button.getAttribute('data-userid');
        });
    </script>
}