@model ProjetoLAWBD.ViewModels.AdminGerirAnunciosViewModel
@{
    ViewData["Title"] = "Gerir Anúncios";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mt-3">Gerir Anúncios</h1>

<form asp-action="GerirAnuncios" method="get">
    <div class="d-flex mb-3 align-items-center">
        <select name="filtroEstado" asp-for="FiltroEstado" asp-items="Model.Estados"
                class="form-select me-2" style="max-width: 200px;">
        </select>

        <input type="text" name="filtroPesquisa" asp-for="FiltroPesquisa"
               class="form-control" placeholder="Pesquisar por Título ou ID..." />

        <button type="submit" class="btn btn-primary ms-2">Filtrar</button>
        <a asp-action="GerirAnuncios" class="btn btn-link text-muted">Limpar</a>
    </div>
</form>

<div class="card shadow-sm anuncio-card">
    <div class="card-body">

        <table class="table table-hover align-middle" style="font-size: 0.9rem;">
            <tbody>
                @foreach (var anuncio in Model.Anuncios)
                {
                    <tr>
                        <td>
                            <b>@anuncio.Titulo</b>
                            <br />
                            <small class="text-muted">ID: @anuncio.Id</small>
                        </td>
                        <td>@anuncio.Vendedor</td>
                        <td>@anuncio.Preco.ToString("C", new System.Globalization.CultureInfo("pt-PT"))</td>
                        <td>
                            @if (anuncio.Estado == "Ativo")
                            {
                                <span class="badge bg-success">ATIVO</span>
                            }
                            else if (anuncio.Estado == "Pausado")
                            {
                                <span class="badge bg-warning text-dark">PAUSADO</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@anuncio.Estado.ToUpper()</span>
                            }
                        </td>
                        <td class="text-end">
                        </td>
                    </tr>
                }

                @if (!Model.Anuncios.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted p-4">
                            Não foram encontrados anúncios com esses filtros.
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>