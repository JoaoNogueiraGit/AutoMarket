@model ProjetoLAWBD.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Finalizar Compra";
}

<div class="container py-5">
    <div class="row g-5">

        <div class="col-md-5 col-lg-4 order-md-last">
            <h4 class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-primary">O teu Pedido</span>
                <span class="badge bg-primary rounded-pill">1</span>
            </h4>
            <ul class="list-group mb-3 shadow-sm">
                <li class="list-group-item d-flex justify-content-between lh-sm p-3">
                    <div class="d-flex align-items-center">
                        <img src="@Url.Content(Model.ImagemUrl)" class="rounded me-3" width="60" height="60" style="object-fit:cover">
                        <div>
                            <h6 class="my-0">@Model.MarcaModelo</h6>
                            <small class="text-muted">@Model.TituloAnuncio</small>
                        </div>
                    </div>
                    <span class="text-muted align-self-center">@Model.Preco.ToString("C0")</span>
                </li>
                <li class="list-group-item d-flex justify-content-between p-3 bg-light">
                    <div class="text-success">
                        <h6 class="my-0">Taxas de Serviço</h6>
                        <small>GRÁTIS</small>
                    </div>
                    <span class="text-success">0,00 €</span>
                </li>
                <li class="list-group-item d-flex justify-content-between p-3">
                    <span>Total (EUR)</span>
                    <strong class="fs-5">@Model.Preco.ToString("C")</strong>
                </li>
            </ul>
        </div>

        <div class="col-md-7 col-lg-8">
            <h4 class="mb-3">Dados de Faturação</h4>
            <form asp-action="ProcessarCompra" method="post" class="needs-validation">
                <input type="hidden" asp-for="AnuncioId" />
                <input type="hidden" asp-for="TituloAnuncio" />
                <input type="hidden" asp-for="Preco" />
                <input type="hidden" asp-for="MarcaModelo" />
                <input type="hidden" asp-for="ImagemUrl" />

                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="NomeFatura" class="form-label">Nome Completo</label>
                        <input asp-for="NomeFatura" class="form-control" placeholder="Nome para a fatura">
                        <span asp-validation-for="NomeFatura" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="RuaENumero" class="form-label">Rua e Número</label>
                        <input asp-for="RuaENumero" class="form-control" placeholder="Ex: Av. da Liberdade, nº 100, 2º Esq">
                        <span asp-validation-for="RuaENumero" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="CodigoPostal" class="form-label">Código Postal</label>
                        <input asp-for="CodigoPostal" class="form-control" placeholder="0000-000">
                        <span asp-validation-for="CodigoPostal" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Cidade" class="form-label">Cidade</label>
                        <input asp-for="Cidade" class="form-control" placeholder="Ex: Lisboa">
                        <span asp-validation-for="Cidade" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Distrito" class="form-label">Distrito</label>
                        <input asp-for="Distrito" class="form-control" placeholder="Ex: Lisboa">
                        <span asp-validation-for="Distrito" class="text-danger small"></span>
                    </div>
                </div>

                <hr class="my-4">

                <h4 class="mb-3">Pagamento</h4>

                <div class="my-3">
                    <div class="form-check">
                        <input id="credit" name="MetodoPagamento" type="radio" class="form-check-input" value="Multibanco" checked required>
                        <label class="form-check-label" for="credit">Referência Multibanco</label>
                    </div>
                    <div class="form-check">
                        <input id="debit" name="MetodoPagamento" type="radio" class="form-check-input" value="MBWay" required>
                        <label class="form-check-label" for="debit">MBWay</label>
                    </div>
                    <div class="form-check">
                        <input id="paypal" name="MetodoPagamento" type="radio" class="form-check-input" value="Transferencia" required>
                        <label class="form-check-label" for="paypal">Transferência Bancária</label>
                    </div>
                </div>

                <hr class="my-4">

                <button class="w-100 btn btn-dark btn-lg" type="submit">
                    Confirmar e Pagar @Model.Preco.ToString("C")
                </button>
            </form>
        </div>
    </div>
</div>