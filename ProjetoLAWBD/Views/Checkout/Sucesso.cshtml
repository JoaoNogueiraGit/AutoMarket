@model int
@{
    ViewData["Title"] = "Compra Confirmada";
}

<div class="container py-5 text-center">
    <div class="card border-0 shadow-sm mx-auto" style="max-width: 600px; border-radius: 15px;">
        <div class="card-body p-5">

            <div class="mb-4 text-success">
                <i class="fas fa-check-circle" style="font-size: 80px;"></i>
            </div>

            <h1 class="h3 fw-bold mb-3">Obrigado pela sua compra!</h1>
            <p class="text-muted mb-4">
                A transação foi concluída com sucesso. O vendedor será notificado e o veículo é oficialmente seu.
            </p>

            <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                <a asp-controller="Comprador" asp-action="VerFatura" asp-route-id="@Model" target="_blank" class="btn btn-dark btn-lg px-4 gap-3">
                    <i class="fas fa-file-invoice me-2"></i>Ver Fatura Oficial
                </a>

                <a asp-controller="Comprador" asp-action="MinhasCompras" class="btn btn-outline-secondary btn-lg px-4">
                    Ir para as Minhas Compras
                </a>
            </div>

            <div class="mt-5 pt-4 border-top">
                <p class="small text-muted mb-0">Enviámos um email de confirmação para a sua conta.</p>
                <small class="text-muted">ID da Transação: #@Model</small>
            </div>
        </div>
    </div>
</div>