@model ProjetoLAWBD.Models.Vendedor
@{
    // 1. Define o Título e o Layout da Dashboard (isto está correto)
    ViewData["Title"] = "Dados de Faturação";
    Layout = "~/Views/Shared/_VendedorLayout.cshtml";
}

<h2 class="h2 pt-4" style="font-weight:bold">@ViewData["Title"]</h2>
<p class="text-muted">Esta informação será usada para processar os seus pagamentos.</p>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["SuccessMessage"]
    </div>
}

<div class="card anuncio-card shadow-sm">
    <div class="card-body">

        <form asp-action="DadosFaturacao" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3">

                <div class="col-md-6">
                    <label asp-for="NIF" class="form-label">NIF (Número de Identificação Fiscal)</label>
                    <input asp-for="NIF" class="form-control" />
                    <span asp-validation-for="NIF" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Tipo de Vendedor</label>
                    <div class="form-check">
                        <input type="radio" asp-for="TipoVendedor" value="Particular" class="form-check-input" id="tipo-particular" />
                        <label class="form-check-label" for="tipo-particular">Particular</label>
                    </div>
                    <div class="form-check">
                        <input type="radio" asp-for="TipoVendedor" value="Empresa" class="form-check-input" id="tipo-empresa" />
                        <label class="form-check-label" for="tipo-empresa">Empresa</label>
                    </div>
                    <span asp-validation-for="TipoVendedor" class="text-danger"></span>
                </div>

                <div class="col-12"><hr class="my-3"></div>

                <div class="col-12">
                    <label asp-for="NomeFaturacao" class="form-label">Nome para Faturação (Empresa ou Pessoal)</label>
                    <input asp-for="NomeFaturacao" class="form-control" />
                    <span asp-validation-for="NomeFaturacao" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="RuaFaturacao" class="form-label">Morada de Faturação</label>
                    <input asp-for="RuaFaturacao" class="form-control" />
                    <span asp-validation-for="RuaFaturacao" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CPFaturacao" class="form-label">Código Postal</label>
                    <input asp-for="CPFaturacao" class="form-control" placeholder="0000-000" />
                    <span asp-validation-for="CPFaturacao" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CidadeFaturacao" class="form-label">Cidade</label>
                    <input asp-for="CidadeFaturacao" class="form-control" />
                    <span asp-validation-for="CidadeFaturacao" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="IBAN" class="form-label">IBAN (Conta Bancária)</label>
                    <input asp-for="IBAN" class="form-control" placeholder="PT50..." />
                    <span asp-validation-for="IBAN" class="text-danger"></span>
                </div>

                <div class="col-12 mt-4">
                    <button type="submit" class="btn btn-dark">Guardar Alterações</button>
                </div>

            </div>
        </form>

    </div>
</div>