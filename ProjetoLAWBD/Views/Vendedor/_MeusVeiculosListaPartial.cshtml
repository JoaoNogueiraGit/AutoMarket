@model ProjetoLAWBD.ViewModels.VendedorMeusVeiculosViewModel

@if (ViewBag.ErrorMessage != null) {
    <div class="alert alert-danger alert-dismissible fade show mb-4 shadow-sm border-danger border-opacity-25" role="alert">
        <div class="d-flex align-items-center">
            <i class="fas fa-exclamation-triangle me-3 fs-4 text-danger"></i>
            <div>
                <strong>Atenção:</strong> @ViewBag.ErrorMessage
            </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (ViewBag.SuccessMessage != null) {
    <div class="alert alert-success alert-dismissible fade show mb-4 shadow-sm border-success border-opacity-25" role="alert">
        <div class="d-flex align-items-center">
            <i class="fas fa-check-circle me-3 fs-4 text-success"></i>
            <div>
                @ViewBag.SuccessMessage
            </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (!Model.Veiculos.Any()) {
    <div class="alert alert-light text-center py-5 shadow-sm border-0">
        <i class="fas fa-car fa-3x text-muted mb-3"></i>
        <h4 class="fw-bold text-muted">Ainda não tem veículos.</h4>
        <p class="text-muted">Adicione o seu primeiro veículo para começar a vender.</p>
    </div>
}
else {
    @foreach (var item in Model.Veiculos) {
        <div class="card anuncio-card shadow-sm mb-3 border-0" style="border-radius: 12px; overflow: hidden;">
            <div class="row g-0 align-items-center">
                @{
                    var img = Model.ImagensDoVeiculos.FirstOrDefault(i => i.IdVeiculo == item.Veiculo.IdVeiculo && i.IsCapa)
                    ?? Model.ImagensDoVeiculos.FirstOrDefault(i => i.IdVeiculo == item.Veiculo.IdVeiculo);
                    var imgUrl = img != null ? Url.Content(img.CaminhoFicheiro) : Url.Content("~/images/placeholder-anuncio.png");
                }

                <div class="col-lg-2 col-md-3 p-2">
                    <div style="height: 120px; width: 100%; overflow: hidden; border-radius: 10px;">
                        <img src="@imgUrl" class="img-fluid" style="width: 100%; height: 100%; object-fit: cover;" />
                    </div>
                </div>

                <div class="col-lg-10 col-md-9">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="fw-bold mb-1 text-dark">@item.Veiculo.Modelo.Marca.Nome @item.Veiculo.Modelo.Nome</h5>
                            <div class="mb-2">
                                @if (item.StatusDoAnuncio == "Vendido") {
                                    <span class="badge bg-success rounded-pill px-3"><i class="fas fa-check-circle me-1"></i> VENDIDO</span>
                                }
                                else if (item.StatusDoAnuncio == "À Venda") {
                                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 border border-primary">À VENDA</span>
                                }
                                else if (item.StatusDoAnuncio == "Reservado") {
                                    <span class="badge bg-warning text-dark rounded-pill px-3">RESERVADO</span>
                                }
                                else if (item.StatusDoAnuncio == "Pausado") {
                                    <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3 border border-warning">PAUSADO</span>
                                }
                                else {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3 border">NÃO LISTADO</span>
                                }
                            </div>
                            <p class="small text-muted mb-0">
                                <i class="far fa-calendar-alt me-1"></i> @item.Veiculo.DataMatricula.Year &bull;
                                <i class="fas fa-road ms-2 me-1"></i> @item.Veiculo.KmTotal.ToString("N0") km
                            </p>
                        </div>

                        <div class="d-flex gap-2 align-items-center">
                            @if (item.StatusDoAnuncio == "Vendido") {
                                <span class="text-muted small fst-italic me-2">Nenhuma ação disponivel</span>
                            }
                            else {
                                <a asp-action="EditarVeiculo" asp-route-id="@item.Veiculo.IdVeiculo" class="btn btn-sm btn-light border text-muted">
                                    Editar
                                </a>

                                <form asp-action="ArquivarVeiculo"
                                      data-ajax="true"
                                      data-ajax-method="post"
                                      data-ajax-mode="replace"
                                      data-ajax-update="#veiculos-container"
                                      data-ajax-confirm="Tem a certeza que deseja arquivar este veículo? Ele sairá desta lista e as fotos serão apagadas."
                                      class="d-inline">

                                    <input type="hidden" name="id" value="@item.Veiculo.IdVeiculo" />
                                    <input type="hidden" name="pageAtual" value="@Model.PageNumber" />

                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Arquivar Veículo">
                                        Remover
                                    </button>
                                </form>

                                @if (item.StatusDoAnuncio == "Não Listado") {
                                    <a asp-action="CriarAnuncio" asp-route-veiculoId="@item.Veiculo.IdVeiculo" class="btn btn-sm btn-dark px-3 fw-bold shadow-sm">
                                        Vender
                                    </a>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (Model.TotalPages > 1) {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++) {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link shadow-none border-0 @(i == Model.PageNumber ? "bg-dark text-white rounded-circle" : "text-muted")"
                           data-ajax="true"
                           data-ajax-method="get"
                           data-ajax-mode="replace"
                           data-ajax-update="#veiculos-container"
                           href="@Url.Action("MeusVeiculos", new { page = i })"
                           style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; margin: 0 5px;">
                            @i
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
}