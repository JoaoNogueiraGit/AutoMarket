@model ProjetoLAWBD.ViewModels.VendedorMeusVeiculosViewModel
@{
    ViewData["Title"] = "Os Meus Veículos";
    Layout = "~/Views/Shared/_VendedorLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2 pt-4 fw-bold">Os Meus Veículos</h1>
        <p class="text-muted">Gerencie o seu inventário de veículos.</p>
    </div>
    <a asp-action="AdicionarVeiculo" class="btn btn-dark shadow-sm">
        <i class="fas fa-plus me-2"></i>Adicionar Novo Veículo
    </a>
</div>

<div id="veiculos-container">
    <partial name="_MeusVeiculosListaPartial" model="Model" />
</div>