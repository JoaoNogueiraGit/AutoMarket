@model ProjetoLAWBD.ViewModels.CriarAnuncioViewModel
@{
    ViewData["Title"] = "Confirmar Publicação";
    Layout = "~/Views/Shared/_VendedorLayout.cshtml";
}

<h2 class="h2 pt-4" style="font-weight:bold">Vender o Meu Veículo</h2>

<hr />

<div class="card anuncio-card shadow-sm">
    <div class="card-body p-4 p-md-5">

        <h4>Confirme os detalhes do anúncio</h4>
        <p class="text-muted">Reveja os detalhes e atribuições antes de publicar.</p>

        <!-- Formulário que submete para a Ação [HttpPost] ConfirmacaoAnuncio -->
        <form asp-action="ConfirmarAnuncio" method="post">
            @Html.AntiForgeryToken()

            <!-- Sumário (baseado no mockup) -->
            <div class="row mt-4">
                <div class="col-md-4">
                    @if (Model.Imagens != null && Model.Imagens.Any()) {
                        <div id="carouselConfirmacao" class="carousel slide shadow-sm rounded overflow-hidden" data-bs-ride="carousel">

                            <!-- Slides -->
                            <div class="carousel-inner">
                                @for (int i = 0; i < Model.Imagens.Count; i++) {
                                    <div class="carousel-item @(i == 0 ? "active" : "")">
                                        <!-- Url.Content() resolve o caminho da imagem -->
                                        <img src="@Url.Content(Model.Imagens[i].CaminhoFicheiro)"
                                             class="d-block w-100"
                                             style="height: 200px; object-fit: cover;"
                                             alt="Foto do veículo">
                                    </div>
                                }
                            </div>

                            <!-- Setas de Navegação (Só mostra se houver mais de 1 imagem) -->
                            @if (Model.Imagens.Count > 1) {
                                <button class="carousel-control-prev" type="button" data-bs-target="#carouselConfirmacao" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Anterior</span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#carouselConfirmacao" data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Seguinte</span>
                                </button>
                            }
                        </div>
                    }
                    else {
                        <!-- Fallback se não houver imagens -->
                        <div class="anuncio-img-container" style="height: 200px; display: flex; align-items: center; justify-content: center; background-color: #f8f9fa; border-radius: 8px;">
                            <img src="~/images/placeholder-anuncio.png" style="max-height: 100%; max-width: 100%; opacity: 0.5;" />
                        </div>
                    }
                </div>
                <div class="col-md-8">
                    <h4>@Model.Anuncio.Titulo</h4>
                    <h3 class="card-price">@Model.Anuncio.Preco.ToString("C", new System.Globalization.CultureInfo("pt-PT"))</h3>

                    <div class="row mt-3">
                        <div class="col-6">
                            <strong>Ano:</strong> @Model.Veiculo.DataMatricula.Year
                        </div>
                        <div class="col-6">
                            <strong>Quilometragem:</strong> @Model.Veiculo.KmTotal km
                        </div>
                        <div class="col-6">
                            <strong>Combustível:</strong> @Model.Veiculo.Combustivel.Nome
                        </div>
                        <div class="col-6">
                            <strong>Caixa:</strong> @Model.Veiculo.Caixa.Nome
                        </div>
                        <div class="col-6">
                            <strong>Cor:</strong> @Model.Veiculo.Cor.Nome
                        </div>
                        <div class="col-6">
                            <strong>Categoria:</strong> @Model.Veiculo.Categoria.Nome
                        </div>
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <!-- Checkbox de Termos -->
            <div class="form-check mb-4">
                <input type="checkbox" class="form-check-input" id="termos" required>
                <label class="form-check-label" for="termos">
                    Li e aceito os <a href="#">Termos de Política e Privacidade</a>
                </label>
            </div>

            <!-- Botões -->
            <div class="text-end">
                <a asp-action="CriarAnuncio" asp-route-veiculoId="@Model.Veiculo.IdVeiculo" class="btn btn-light me-2">Cancelar</a>
                <button type="submit" class="btn btn-dark">Publicar Anúncio</button>
            </div>
        </form>
    </div>
</div>