@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Esqueceu-se da palavra-passe?";
    // O teu layout principal (se o teu login o usa)
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}

<div class="registration-container">

    <form method="post">
        
        <h2 class="text-center">@ViewData["Title"]</h2>
        <p class="text-center text-muted mb-4">Insira o seu email e enviaremos um link para recuperar a sua conta.</p>

        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
        
        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="teu@email.com" />
            <label asp-for="Input.Email" class="form-label"></label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>
        
        <button type="submit" class="w-100 btn btn-lg btn-dark">Enviar link de recuperação</button>
        
        <div class="login-links mt-4">
            <p>
                Lembrou-se da palavra-passe? 
                <a asp-page="./Login">Voltar ao Login</a>
            </p>
        </div>

    </form>

</div>

@section Styles {
    <link rel="stylesheet" href="~/css/auth-layout.css" asp-append-version="true" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}