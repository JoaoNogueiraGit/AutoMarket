@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Email Confirmado";
    // Verificamos se a mensagem de status indica erro ou sucesso
    // O Identity por defeito mete "Error" no início da string se falhar.
    bool sucesso = Model.StatusMessage != null && !Model.StatusMessage.StartsWith("Error");
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 60vh;">
    <div class="card shadow-sm border-0" style="width: 100%; max-width: 500px; border-radius: 15px;">
        <div class="card-body p-5 text-center">

            @if (sucesso) {

                <h2 class="fw-bold text-dark mb-3">Email Confirmado!</h2>
                <p class="text-muted mb-4">
                    A sua conta foi ativada com sucesso.<br>
                    Já pode entrar no AutoMarket e começar a comprar ou vender.
                </p>

                <a asp-page="./Login" class="btn btn-dark w-100 py-2 fw-bold" style="border-radius: 8px;">
                    Ir para o Login
                </a>
            }
            else {
                
                <h2 class="fw-bold text-danger mb-3">Algo correu mal</h2>
                <p class="text-muted mb-4">
                    Não foi possível confirmar o seu email. O link pode ser inválido ou ter expirado.
                </p>

                <p class="small text-danger bg-danger bg-opacity-10 p-2 rounded">
                    @Model.StatusMessage
                </p>

                <a asp-page="./Index" class="btn btn-outline-secondary w-100 mt-2">
                    Voltar à Página Inicial
                </a>
            }

        </div>
    </div>
</div>