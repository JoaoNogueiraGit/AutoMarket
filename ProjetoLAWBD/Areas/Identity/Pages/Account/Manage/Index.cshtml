@page
@model IndexModel
@{
    ViewData["Title"] = "O Meu Perfil";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h2 class="h2 pt-4 fw-bold">@ViewData["Title"]</h2>
<p class="text-muted">Atualize as suas informações de conta.</p>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light fw-bold">Dados Principais</div>
            <div class="card-body p-4">
                <form id="profile-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.NomeCompleto" class="form-label fw-bold"></label>
                        <input asp-for="Input.NomeCompleto" class="form-control" />
                        <span asp-validation-for="Input.NomeCompleto" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label text-muted small">Username</label>
                        <input asp-for="Username" class="form-control" disabled />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label text-muted small">Email da Conta</label>
                        <div class="input-group">
                            <input asp-for="Email" class="form-control" disabled />
                            <a asp-page="./Email" class="btn btn-outline-secondary">Alterar</a>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a asp-page="./ChangePassword" class="small text-decoration-none">Alterar Password?</a>
                        <button id="update-profile-button" type="submit" class="btn btn-dark">Guardar Nome</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-light fw-bold">Contactos Adicionais</div>
            <div class="card-body p-4">
                <p class="small text-muted">Adicione telemóveis, WhatsApp ou emails alternativos para os compradores o contactarem.</p>

                @if (Model.ListaContactos != null && Model.ListaContactos.Any()) {
                    <div class="list-group mb-4">
                        @foreach (var c in Model.ListaContactos) {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="badge bg-secondary me-2">@c.TipoContacto</span>
                                    <span class="fw-bold text-dark">@c.ValorContacto</span>
                                </div>

                                <form method="post" asp-page-handler="RemoverContacto" asp-route-idContacto="@c.IdContacto" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger border-0" title="Remover">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                }
                else {
                    <div class="alert alert-light text-center border mb-4">
                        <small>Ainda não adicionou contactos extra.</small>
                    </div>
                }

                <hr />

                <h6 class="fw-bold mb-3"><i class="fas fa-plus-circle me-2"></i>Novo Contacto</h6>
                <form method="post" asp-page-handler="AdicionarContacto">
                    <div class="row g-2">
                        <div class="col-4">
                            <select asp-for="Input.NovoTipoContacto" class="form-select form-select-sm">
                                <option value="Telemóvel">Telemóvel</option>
                                <option value="WhatsApp">WhatsApp</option>
                                <option value="Email">Email</option>
                                <option value="Telefone Fixo">Fixo</option>
                            </select>
                        </div>
                        <div class="col-8">
                            <div class="input-group input-group-sm">
                                <input asp-for="Input.NovoValorContacto" class="form-control" placeholder="Ex: 912 345 678" required />
                                <button type="submit" class="btn btn-success">Adicionar</button>
                            </div>
                        </div>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}