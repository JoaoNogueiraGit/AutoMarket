@page
@model EmailModel
@{
    ViewData["Title"] = "Gerir Email";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<h3 class="fw-bold mb-1">@ViewData["Title"]</h3>
<p class="text-muted mb-4">Mantenha o seu endereço de email atualizado e verificado.</p>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="card shadow-sm border-0">
    <div class="card-body p-4 p-md-5">
        <form id="email-form" method="post">

            <div asp-validation-summary="All" class="text-danger mb-3" role="alert"></div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label text-muted small fw-bold">Email Atual</label>

                @if (Model.IsEmailConfirmed) {
                    <div class="input-group">
                        <input asp-for="Email" class="form-control bg-light" disabled />
                        <span class="input-group-text bg-success text-white border-success" title="Verificado">
                            <i class="fas fa-check-circle"></i>
                        </span>
                    </div>
                    <div class="form-text text-success">
                        <i class="fas fa-shield-alt me-1"></i> A sua conta está verificada.
                    </div>
                }
                else {
                    <input asp-for="Email" class="form-control bg-light" disabled />
                    <button id="email-verification" type="submit" asp-page-handler="SendVerificationEmail" class="btn btn-link px-0 text-decoration-none text-warning">
                        <i class="fas fa-exclamation-triangle me-1"></i> Enviar email de verificação
                    </button>
                }
            </div>

            <div class="mb-4">
                <label asp-for="Input.NewEmail" class="form-label text-muted small fw-bold">Novo Email</label>
                <div class="input-group">
                    <span class="input-group-text bg-white text-muted border-end-0">
                        <i class="fas fa-envelope"></i>
                    </span>
                    <input asp-for="Input.NewEmail" class="form-control border-start-0" autocomplete="email" aria-required="true" placeholder="Insira o novo endereço..." />
                </div>
                <span asp-validation-for="Input.NewEmail" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-end mt-4">
                <button id="change-email-button" type="submit" asp-page-handler="ChangeEmail" class="btn btn-dark">
                    Alterar Email
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}