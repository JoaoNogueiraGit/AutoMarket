@page
@using Microsoft.AspNetCore.Http.Features
@model TwoFactorAuthenticationModel
@{
    ViewData["Title"] = "Autenticação de Dois Fatores (2FA)";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<h3 class="fw-bold mb-1">@ViewData["Title"]</h3>
<p class="text-muted mb-4">Aumente a segurança da sua conta exigindo uma segunda etapa de verificação ao entrar.</p>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="card shadow-sm border-0">
    <div class="card-body p-4 p-md-5">

        @{
            var consentFeature = HttpContext.Features.Get<ITrackingConsentFeature>();
            @if (consentFeature?.CanTrack ?? true) {
                // 1. ESTADO ATUAL DO 2FA
                @if (Model.Is2faEnabled) {
                    <div class="alert alert-success d-flex align-items-center shadow-sm border-success mb-4" role="alert">
                        <i class="fas fa-check-circle fa-2x me-3"></i>
                        <div>
                            <h5 class="alert-heading h6 fw-bold mb-0">O 2FA está ativado</h5>
                            <small>A sua conta está protegida.</small>
                        </div>
                    </div>

                    // 2. AVISOS DE CÓDIGOS DE RECUPERAÇÃO
                    if (Model.RecoveryCodesLeft == 0) {
                        <div class="alert alert-danger d-flex align-items-center mb-4">
                            <i class="fas fa-exclamation-triangle fa-lg me-3"></i>
                            <div>
                                <strong>Não tem códigos de recuperação restantes.</strong>
                                <br>Deve <a asp-page="./GenerateRecoveryCodes" class="alert-link">gerar um novo conjunto</a> antes de poder usar um código para entrar.
                            </div>
                        </div>
                    }
                    else if (Model.RecoveryCodesLeft == 1) {
                        <div class="alert alert-danger d-flex align-items-center mb-4">
                            <i class="fas fa-exclamation-circle fa-lg me-3"></i>
                            <div>
                                <strong>Resta apenas 1 código de recuperação.</strong>
                                <br>Pode <a asp-page="./GenerateRecoveryCodes" class="alert-link">gerar novos códigos</a>.
                            </div>
                        </div>
                    }
                    else if (Model.RecoveryCodesLeft <= 3) {
                        <div class="alert alert-warning d-flex align-items-center mb-4">
                            <i class="fas fa-info-circle fa-lg me-3"></i>
                            <div>
                                <strong>Restam @Model.RecoveryCodesLeft códigos de recuperação.</strong>
                                <br>Deve <a asp-page="./GenerateRecoveryCodes" class="alert-link">gerar novos códigos</a>.
                            </div>
                        </div>
                    }

                    // 3. AÇÕES GERAIS (Botões)
                    <div class="d-flex flex-wrap gap-2 mb-5">
                        @if (Model.IsMachineRemembered) {
                            <form method="post" style="display: inline-block">
                                <button type="submit" class="btn btn-outline-secondary">
                                    <i class="fas fa-history me-1"></i> Esquecer este navegador
                                </button>
                            </form>
                        }

                        <a asp-page="./Disable2fa" class="btn btn-outline-danger">
                            <i class="fas fa-ban me-1"></i> Desativar 2FA
                        </a>

                        <a asp-page="./GenerateRecoveryCodes" class="btn btn-outline-dark">
                            <i class="fas fa-sync-alt me-1"></i> Redefinir códigos de recuperação
                        </a>
                    </div>
                }
                else {
                    // ESTADO DESATIVADO
                    <div class="alert alert-light border d-flex align-items-center mb-4 text-muted">
                        <i class="fas fa-shield-alt fa-2x me-3"></i>
                        <div>
                            <h5 class="alert-heading h6 fw-bold mb-0">O 2FA não está ativado</h5>
                            <small>Proteja a sua conta ativando uma aplicação autenticadora.</small>
                        </div>
                    </div>
                }

                <hr class="my-4">

                // 4. CONFIGURAÇÃO DA APP AUTENTICADORA
                <h5 class="fw-bold mb-3">Aplicação Autenticadora</h5>

                @if (!Model.HasAuthenticator) {
                    <p class="text-muted small mb-3">Use aplicações como Microsoft Authenticator ou Google Authenticator.</p>
                    <a id="enable-authenticator" asp-page="./EnableAuthenticator" class="btn btn-dark">
                        <i class="fas fa-plus me-2"></i>Adicionar aplicação autenticadora
                    </a>
                }
                else {
                    <div class="d-flex flex-wrap gap-2">
                        <a id="enable-authenticator" asp-page="./EnableAuthenticator" class="btn btn-dark">
                            <i class="fas fa-cog me-2"></i>Configurar aplicação
                        </a>
                        <a id="reset-authenticator" asp-page="./ResetAuthenticator" class="btn btn-outline-danger">
                            <i class="fas fa-trash-alt me-2"></i>Redefinir aplicação
                        </a>
                    </div>
                }
            }
            else {
                // AVISO DE COOKIES
                <div class="alert alert-danger border-danger shadow-sm">
                    <h5 class="alert-heading h6 fw-bold"><i class="fas fa-cookie-bite me-2"></i>Política de Privacidade e Cookies</h5>
                    <p class="mb-0 small">Tem de aceitar a política de cookies antes de poder ativar a autenticação de dois fatores.</p>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}